{
    "functions": {
        "api/index.py": {
            "includeFiles": [
                "app/templates/**",
                "app/static/**"
            ]
        }
    },
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.py"
        }
    ]
}
